# ThirdLeg Production Environment Variables
# Copy this file to .env and fill in your actual values
SPRING_APPLICATION_JSON='{
	"spring.datasource.url": "jdbc:mariadb://mariadb:3306/thirdleg",
      	"spring.datasource.username": "thirdleg",
      	"spring.datasource.password": "CHANGE_ME",
      	"spring.ai.ollama.base-url": "http://ollama:11434",
      	"spring.ai.ollama.chat.options.model": "llama3.1",
      	"app.scheduling.enabled": "true",
      	"app.scheduling.data-fetch-cron": "0 30 1 * * ?",
      	"app.scheduling.indicator-calculation-cron": "0 45 1 * * ?",
	"app.ollama.native.base-url": "http://ollama:11434",
	"app.ollama.native.request-timeout-seconds": 1800
}'

# Domain configuration
THIRDLEG_DOMAIN=thirdleg.example.com

# Scheduling configuration (set to false to disable scheduled jobs)
THIRDLEG_SCHEDULING_ENABLED=true

# GitHub Container Registry (for pulling images)
# If your images are private, you may need to:
# docker login ghcr.io -u piotrraszkowski -p YOUR_GITHUB_TOKEN
